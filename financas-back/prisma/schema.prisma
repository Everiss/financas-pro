generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  firebaseUid       String    @unique @map("firebase_uid")
  displayName       String    @map("display_name")
  email             String    @unique
  photoURL          String?   @map("photo_url") @db.Text
  currency          String    @default("BRL")
  plan              PlanType  @default(FREE)
  stripeCustomerId  String?   @unique @map("stripe_customer_id")
  trialEndsAt       DateTime? @map("trial_ends_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  banks           Bank[]
  accounts        BankAccount[]
  categories      Category[]
  transactions    Transaction[]
  reminders       Reminder[]
  goals           Goal[]
  transfers       Transfer[]
  aiInsightCache  AiInsightCache?
  auditLogs       AuditLog[]
  subscription    Subscription?

  @@map("users")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripePriceId        String             @map("stripe_price_id")
  status               SubscriptionStatus
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model Bank {
  id        String        @id @default(uuid())
  name      String
  color     String        @default("#3b82f6")
  icon      String        @default("Landmark")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  userId   String        @map("user_id")
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts BankAccount[]

  @@index([userId])
  @@map("banks")
}

model BankAccount {
  id             String          @id @default(uuid())
  name           String
  type           AccountType
  balance        Decimal         @default(0) @db.Decimal(15, 2)
  color          String          @default("#3b82f6")
  icon           String          @default("Wallet")
  creditLimit    Decimal?        @map("credit_limit") @db.Decimal(15, 2)
  closingDay     Int?            @map("closing_day")
  dueDay         Int?            @map("due_day")
  investmentType InvestmentType? @map("investment_type")
  subtype        String?         @db.VarChar(50)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  userId       String        @map("user_id")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankId       String?       @map("bank_id")
  bank         Bank?         @relation(fields: [bankId], references: [id], onDelete: SetNull)
  transactions  Transaction[]
  reminders     Reminder[]
  transfersFrom Transfer[] @relation("TransferFromAccount")
  transfersTo   Transfer[] @relation("TransferToAccount")

  @@index([userId])
  @@index([bankId])
  @@map("bank_accounts")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String   @default("MoreHorizontal")
  color     String   @default("#71717a")
  budget    Decimal? @db.Decimal(15, 2)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId       String?       @map("user_id")
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  reminders    Reminder[]

  @@index([userId])
  @@map("categories")
}

model Transaction {
  id            String          @id @default(uuid())
  amount        Decimal         @db.Decimal(15, 2)
  type          TransactionType
  description   String?         @db.Text
  date          DateTime
  paymentMethod PaymentMethod?  @map("payment_method")
  isTransfer    Boolean         @default(false) @map("is_transfer")
  transferId    String?         @map("transfer_id")
  transferFrom  Transfer?       @relation("TransferFrom")
  transferTo    Transfer?       @relation("TransferTo")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  userId     String       @map("user_id")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId  String?      @map("account_id")
  account    BankAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId String?      @map("category_id")
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([accountId])
  @@index([categoryId])
  @@map("transactions")
}

model Reminder {
  id        String          @id @default(uuid())
  title     String
  amount    Decimal         @db.Decimal(15, 2)
  type      TransactionType
  dueDate   DateTime        @map("due_date")
  frequency FrequencyType
  notes     String?         @db.Text
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  userId     String       @map("user_id")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId  String?      @map("account_id")
  account    BankAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId String?      @map("category_id")
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, dueDate])
  @@index([accountId])
  @@index([categoryId])
  @@map("reminders")
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    AuditAction
  entity    AuditEntity
  entityId  String?     @map("entity_id")
  payload   String?     @db.Text
  ip        String?
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model AiInsightCache {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  insightsJson String?  @map("insights_json") @db.Text
  strategyJson String?  @map("strategy_json") @db.Text
  extraJson    String?  @map("extra_json") @db.Text
  isDirty      Boolean  @default(true) @map("is_dirty")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ai_insight_cache")
}

model Goal {
  id            String       @id @default(uuid())
  name          String
  targetAmount  Decimal      @map("target_amount") @db.Decimal(15, 2)
  currentAmount Decimal      @default(0) @map("current_amount") @db.Decimal(15, 2)
  deadline      DateTime?
  category      GoalCategory
  color         String?      @default("#3b82f6")
  icon          String?      @default("Target")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("goals")
}

model Transfer {
  id            String      @id @default(uuid())
  amount        Decimal     @db.Decimal(15, 2)
  date          DateTime
  description   String?     @db.Text
  isBillPayment Boolean     @default(false) @map("is_bill_payment")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromAccountId String      @map("from_account_id")
  fromAccount   BankAccount @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Cascade)

  toAccountId   String      @map("to_account_id")
  toAccount     BankAccount @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  fromTxId      String      @unique @map("from_tx_id")
  fromTx        Transaction @relation("TransferFrom", fields: [fromTxId], references: [id], onDelete: Cascade)

  toTxId        String      @unique @map("to_tx_id")
  toTx          Transaction @relation("TransferTo", fields: [toTxId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transfers")
}

// --- Enums ---

enum AccountType {
  checking
  savings
  investment
  credit
}

enum InvestmentType {
  cdb
  stock
  fund
  fii
  other
  tesouro
  previdencia
  crypto
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  debit
  credit
}

enum FrequencyType {
  once
  daily
  weekly
  monthly
  yearly
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntity {
  TRANSACTION
  ACCOUNT
  BANK
  GOAL
  REMINDER
  CATEGORY
  TRANSFER
}

enum PlanType {
  FREE
  PRO
  FAMILY
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
}

enum GoalCategory {
  Viagem
  Casa
  Carro
  Educacao
  ReservaDeEmergencia
  Aposentadoria
  Outros
}
