generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  firebaseUid       String    @unique @map("firebase_uid")
  displayName       String    @map("display_name")
  email             String    @unique
  photoURL          String?   @map("photo_url") @db.Text
  currency          String    @default("BRL")
  plan              PlanType  @default(FREE)
  stripeCustomerId  String?   @unique @map("stripe_customer_id")
  trialEndsAt       DateTime? @map("trial_ends_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  banks           Bank[]
  accounts        BankAccount[]
  categories      Category[]
  transactions    Transaction[]
  reminders       Reminder[]
  goals           Goal[]
  transfers       Transfer[]
  receipts        Receipt[]
  aiInsightCache  AiInsightCache?
  auditLogs       AuditLog[]
  subscription    Subscription?
  settings        UserSettings?

  @@map("users")
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Comunicação
  emailNotifications Boolean @default(true)  @map("email_notifications")
  weeklyReport       Boolean @default(true)  @map("weekly_report")
  monthlyReport      Boolean @default(true)  @map("monthly_report")
  pushNotifications  Boolean @default(true)  @map("push_notifications")

  // Lembretes
  reminderAdvanceDays Int    @default(3)       @map("reminder_advance_days")
  reminderFrequency   String @default("daily") @map("reminder_frequency") @db.VarChar(20)

  // Alertas
  budgetAlertThreshold  Int   @default(80)  @map("budget_alert_threshold")
  lowBalanceAlert       Float @default(100) @map("low_balance_alert")
  largeTransactionAlert Float @default(500) @map("large_transaction_alert")
  creditUsageAlert      Int   @default(70)  @map("credit_usage_alert")

  // Saúde financeira
  emergencyFundMonths Float @default(6)  @map("emergency_fund_months")
  savingsRateTarget   Int   @default(20) @map("savings_rate_target")
  debtIncomeLimit     Int   @default(30) @map("debt_income_limit")

  // Investimentos
  riskProfile        String  @default("moderate") @map("risk_profile") @db.VarChar(20)
  rebalanceAlert     Boolean @default(true)        @map("rebalance_alert")
  rebalanceThreshold Int     @default(5)           @map("rebalance_threshold")
  fixedIncomeTarget  Int     @default(40)          @map("fixed_income_target")
  variableTarget     Int     @default(40)          @map("variable_target")
  internationalTarget Int    @default(20)          @map("international_target")

  // Notícias
  showMarketNews   Boolean @default(true) @map("show_market_news")
  showEconomicNews Boolean @default(true) @map("show_economic_news")
  showPersonalTips Boolean @default(true) @map("show_personal_tips")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@map("user_settings")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripePriceId        String             @map("stripe_price_id")
  status               SubscriptionStatus
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model Bank {
  id        String        @id @default(uuid())
  name      String
  color     String        @default("#3b82f6")
  icon      String        @default("Landmark")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  userId   String        @map("user_id")
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts BankAccount[]

  @@index([userId])
  @@map("banks")
}

model BankAccount {
  id             String          @id @default(uuid())
  name           String
  type           AccountType
  balance        Decimal         @default(0) @db.Decimal(15, 2)
  color          String          @default("#3b82f6")
  icon           String          @default("Wallet")
  creditLimit    Decimal?        @map("credit_limit") @db.Decimal(15, 2)
  closingDay     Int?            @map("closing_day")
  dueDay         Int?            @map("due_day")
  investmentType InvestmentType? @map("investment_type")
  subtype        String?         @db.VarChar(50)
  currency       String          @default("BRL") @db.VarChar(3)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  userId       String        @map("user_id")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankId       String?       @map("bank_id")
  bank         Bank?         @relation(fields: [bankId], references: [id], onDelete: SetNull)
  transactions  Transaction[]
  reminders     Reminder[]
  transfersFrom Transfer[] @relation("TransferFromAccount")
  transfersTo   Transfer[] @relation("TransferToAccount")

  @@index([userId])
  @@index([bankId])
  @@map("bank_accounts")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String   @default("MoreHorizontal")
  color     String   @default("#71717a")
  budget    Decimal? @db.Decimal(15, 2)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId       String?       @map("user_id")
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  reminders    Reminder[]
  receiptItems ReceiptItem[]

  @@index([userId])
  @@map("categories")
}

model Transaction {
  id            String          @id @default(uuid())
  amount        Decimal         @db.Decimal(15, 2)
  type          TransactionType
  description   String?         @db.Text
  date          DateTime
  paymentMethod PaymentMethod?  @map("payment_method")
  isPending     Boolean         @default(false) @map("is_pending")
  installmentRef String?        @map("installment_ref") @db.VarChar(64)
  isTransfer    Boolean         @default(false) @map("is_transfer")
  transferId    String?         @map("transfer_id")
  transferFrom  Transfer?       @relation("TransferFrom")
  transferTo    Transfer?       @relation("TransferTo")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  userId     String       @map("user_id")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId  String?      @map("account_id")
  account    BankAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId String?      @map("category_id")
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  receipt    Receipt?

  @@index([userId, date])
  @@index([userId, type])
  @@index([accountId])
  @@index([categoryId])
  @@map("transactions")
}

model Reminder {
  id        String          @id @default(uuid())
  title     String
  amount    Decimal         @db.Decimal(15, 2)
  type      TransactionType
  dueDate   DateTime        @map("due_date")
  frequency FrequencyType
  notes     String?         @db.Text
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  userId     String       @map("user_id")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId  String?      @map("account_id")
  account    BankAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId String?      @map("category_id")
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, dueDate])
  @@index([accountId])
  @@index([categoryId])
  @@map("reminders")
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    AuditAction
  entity    AuditEntity
  entityId  String?     @map("entity_id")
  payload   String?     @db.Text
  ip        String?
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model AiInsightCache {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  insightsJson String?  @map("insights_json") @db.Text
  strategyJson String?  @map("strategy_json") @db.Text
  extraJson    String?  @map("extra_json") @db.Text
  isDirty      Boolean  @default(true) @map("is_dirty")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ai_insight_cache")
}

model Goal {
  id            String       @id @default(uuid())
  name          String
  targetAmount  Decimal      @map("target_amount") @db.Decimal(15, 2)
  currentAmount Decimal      @default(0) @map("current_amount") @db.Decimal(15, 2)
  deadline      DateTime?
  category      GoalCategory
  color         String?      @default("#3b82f6")
  icon          String?      @default("Target")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("goals")
}

model Transfer {
  id            String      @id @default(uuid())
  amount        Decimal     @db.Decimal(15, 2)
  date          DateTime
  description   String?     @db.Text
  isBillPayment Boolean     @default(false) @map("is_bill_payment")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromAccountId String      @map("from_account_id")
  fromAccount   BankAccount @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Cascade)

  toAccountId   String      @map("to_account_id")
  toAccount     BankAccount @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  fromTxId      String      @unique @map("from_tx_id")
  fromTx        Transaction @relation("TransferFrom", fields: [fromTxId], references: [id], onDelete: Cascade)

  toTxId        String      @unique @map("to_tx_id")
  toTx          Transaction @relation("TransferTo", fields: [toTxId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transfers")
}

model Receipt {
  id            String        @id @default(uuid())
  issuerName    String?       @map("issuer_name") @db.VarChar(200)
  issuerCnpj    String?       @map("issuer_cnpj") @db.VarChar(20)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(15, 2)
  issueDate     DateTime?     @map("issue_date")
  accessKey     String?       @map("access_key") @db.VarChar(50)
  source        String        @default("image") @db.VarChar(20)
  createdAt     DateTime      @default(now()) @map("created_at")

  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String?       @unique @map("transaction_id")
  transaction   Transaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  items         ReceiptItem[]

  @@index([userId])
  @@map("receipts")
}

model ReceiptItem {
  id          String    @id @default(uuid())
  description String    @db.VarChar(300)
  quantity    Decimal   @db.Decimal(10, 3)
  unit        String?   @db.VarChar(10)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(15, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(15, 2)

  receiptId   String    @map("receipt_id")
  receipt     Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  categoryId  String?   @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([receiptId])
  @@map("receipt_items")
}

// --- Enums ---

enum AccountType {
  checking
  savings
  investment
  credit
  loan
  financing
}

enum InvestmentType {
  cdb
  stock
  fund
  fii
  other
  tesouro
  previdencia
  crypto
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  debit
  credit
}

enum FrequencyType {
  once
  daily
  weekly
  monthly
  yearly
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntity {
  TRANSACTION
  ACCOUNT
  BANK
  GOAL
  REMINDER
  CATEGORY
  TRANSFER
}

enum PlanType {
  FREE
  PRO
  FAMILY
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
}

enum GoalCategory {
  Viagem
  Casa
  Carro
  Educacao
  ReservaDeEmergencia
  Aposentadoria
  Outros
}
